{
  "name": "mock-extended",
  "private": true,
  "packageManager": "bun@1.2.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "test": "bun test",
    "test:mock-extended": "bun test packages/mock-extended/test",
    "typecheck": "tsc -b",
    "ci": "bun run check && bun run typecheck && bun run test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/bun": "^1.3.10",
    "typescript": "^5.8.0"
  }
}
