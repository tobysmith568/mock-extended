---
const compatibilityItems = [
  {
    name: "Jest, Vitest, Bun, node:test, Sinon, and more",
    detail: "Plug in your own mock function style while keeping one typed API.",
  },
  {
    name: "Zero runtime dependencies",
    detail: "Keep your dependency tree lean with no framework lock-in baggage.",
  },
  {
    name: "Built for migrations",
    detail:
      "Switch runners and runtimes without rewriting your typed mocks from scratch.",
  },
];
---

<section class="splash" aria-labelledby="hero-title">
  <p class="splashKicker">mock-extended</p>
  <h1 id="hero-title" class="splashTitle">
    Type-safe mocks without the framework lock-in.
  </h1>
  <p class="splashSummary">
    Build resilient test doubles for interfaces and classes using your preferred
    test runner, while keeping strict TypeScript behavior across the entire
    suite.
  </p>
  <div class="splashActions">
    <a class="button buttonPrimary" href="/docs/getting-started">
      Get started
    </a>
    <a class="button buttonSecondary" href="/docs/examples">
      Browse examples
    </a>
  </div>
  <section class="compatibility" aria-label="Why teams choose mock-extended">
    <ul class="compatibilityList">
      {
        compatibilityItems.map((item) => (
          <li class="compatibilityItem">
            <p class="compatibilityName">{item.name}</p>
            <p class="compatibilityDetail">{item.detail}</p>
          </li>
        ))
      }
    </ul>
  </section>
</section>

<style>
  .splash {
    max-width: 58rem;
    background: var(--surface-glass);
    border: 1px solid var(--surface-glass-line);
    border-radius: 28px;
    padding: 3.25rem;
    box-shadow: var(--shadow);
    animation: rise-in 500ms ease-out;
  }

  .splashKicker {
    margin: 0;
    font-size: 0.88rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--brand);
    font-weight: 700;
  }

  .splashTitle {
    margin: 0.7rem 0 1rem;
    font-size: clamp(2rem, 4.2vw, 3.5rem);
    line-height: 1.1;
  }

  .splashSummary {
    margin: 0;
    max-width: 56ch;
    color: var(--ink-soft);
    font-size: 1.08rem;
    line-height: 1.7;
  }

  .splashActions {
    margin-top: 1.7rem;
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.72rem 1.05rem;
    border-radius: 999px;
    font-weight: 600;
    transition:
      transform 140ms ease,
      box-shadow 140ms ease;
  }

  .button:hover {
    text-decoration: none;
    transform: translateY(-2px);
  }

  .buttonPrimary {
    background: var(--brand);
    color: #ffffff;
    box-shadow: 0 8px 24px rgba(17, 94, 84, 0.25);
  }

  .buttonSecondary {
    background: var(--surface-soft);
    border: 1px solid var(--line);
    color: var(--ink);
  }

  .compatibility {
    margin-top: 1.6rem;
    display: grid;
    gap: 0.9rem;
  }

  .compatibilityList {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0.6rem;
  }

  .compatibilityItem {
    background: var(--surface-soft);
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 0.75rem 0.85rem;
  }

  .compatibilityName {
    margin: 0;
    color: var(--ink);
    font-weight: 650;
    font-size: 0.95rem;
  }

  .compatibilityDetail {
    margin: 0.35rem 0 0;
    color: var(--ink-soft);
    line-height: 1.45;
    font-size: 0.92rem;
  }

  @keyframes rise-in {
    from {
      opacity: 0;
      transform: translateY(14px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 900px) {
    .splash {
      padding: 2rem 1.2rem;
    }
  }
</style>
