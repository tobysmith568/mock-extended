{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "paths": {
      "mock-extended": ["../mock-extended/src/index.ts"]
    },
    "types": ["node", "jest"],
    "esModuleInterop": true,
    "verbatimModuleSyntax": false,
    "noEmit": true
  },
  "include": ["src/**/*.ts"]
}
